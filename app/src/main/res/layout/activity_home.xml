<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA"
    android:padding="24dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layoutDirection="rtl">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Welcome back!"
            android:textColor="#111827"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Choose an option to get started."
            android:textColor="#6B7280"
            android:textSize="16sp" />

        <!-- Space -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp" />

        <!-- Workout Programs Button -->
        <Button
            android:id="@+id/btnWorkoutPrograms"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="My Workout Programs"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:backgroundTint="@android:color/black"
            android:layout_marginBottom="12dp"
            android:onClick="goToWorkoutPrograms" />

        <!-- Generate New Program Button -->
        <Button
            android:id="@+id/btnGenerateProgram"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Generate New Program"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:backgroundTint="@android:color/black"
            android:layout_marginBottom="12dp"
            android:onClick="goToGenerateProgram" />

        <!-- Progress Button -->
        <Button
            android:id="@+id/btnProgress"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="My Progress"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:backgroundTint="@android:color/black"
            android:layout_marginBottom="12dp"
            android:onClick="goToProgress" />

        <!-- Profile Button -->
        <Button
            android:id="@+id/btnProfile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Profile"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:backgroundTint="@android:color/black"
            android:layout_marginBottom="12dp"
            android:onClick="goToProfile" />

        <!-- Logout Button -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Log Out"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:backgroundTint="#E0E0E0"
            android:layout_marginBottom="12dp"
            android:onClick="logout" />

    </LinearLayout>
</ScrollView>